{
  "name": "workar-server",
  "version": "0.1.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/damiant/workar.git",
    "directory": "server-cli"
  },
  "bin": {
    "workar-server": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "prepack": "mkdir -p image-gen-cli tts-cli/src && cp ../image-gen-cli/src/*.js image-gen-cli/ && cp ../tts-cli/src/*.js tts-cli/src/"
  },
  "files": [
    "dist/",
    "image-gen-cli/",
    "tts-cli/",
    "work-defs.json",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "kokoro-js": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
