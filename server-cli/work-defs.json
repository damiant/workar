[
  {
    "type": "image-gen",
    "commands": [
      "node __PKG_DIR__/image-gen-cli/cli.js -p @prompt -m @model -o @timestamp.png"
    ],
    "contentType": "image/png",
    "outputFile": "@timestamp.png",
    "defaults": {
      "model": "sdxl-lightning"
    }
  },
  {
    "type": "tts",
    "commands": [
      "node __PKG_DIR__/tts-cli/src/cli.js -t @text -v @voice -s @speed -o @timestamp.wav"
    ],
    "contentType": "audio/wav",
    "outputFile": "@timestamp.wav",
    "defaults": {
      "voice": "af_heart",
      "speed": "1"
    }
  }
]
